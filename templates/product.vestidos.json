        "custom_liquid_sizeguide": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{%- unless product.description contains \"Guía de Tallas\" or product.description contains \"cr-sg-wrap\" -%}<div class=\"cr-sg-wrap\" data-sg-parent><button class=\"cr-sg-btn\" type=\"button\" data-sg-trigger aria-expanded=\"false\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><path d=\"M3 6h18M3 10h18M3 14h12\"/></svg><span>Guía de Tallas</span><svg class=\"cr-sg-chevron\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"cr-sg-panel\" data-sg-panel hidden><div class=\"cr-sg-inner\"><p class=\"cr-sg-tip\">Tejidos elásticos · Si dudas entre dos tallas, elige la más pequeña para un ajuste óptimo.</p><div style=\"overflow-x:auto;-webkit-overflow-scrolling:touch\"><table class=\"cr-sg-table\"><thead><tr><th>Talla EU</th><th>Busto (cm)</th><th>Cintura (cm)</th><th>Cadera (cm)</th></tr></thead><tbody><tr><td>XS</td><td>80–84</td><td>62–66</td><td>87–91</td></tr><tr><td>S</td><td>84–88</td><td>66–70</td><td>91–95</td></tr><tr><td>M</td><td>88–92</td><td>70–74</td><td>95–99</td></tr><tr><td>L</td><td>92–97</td><td>74–79</td><td>99–104</td></tr><tr><td>XL</td><td>97–103</td><td>79–85</td><td>104–110</td></tr><tr><td>XXL</td><td>103–110</td><td>85–92</td><td>110–117</td></tr></tbody></table></div><p class=\"cr-sg-note\">Si necesitas ayuda, escíbenos a claraareyeess@gmail.com</p></div></div></div><script>(function(){document.querySelectorAll(\"[data-sg-parent]\").forEach(function(w){var b=w.querySelector(\"[data-sg-trigger]\"),p=w.querySelector(\"[data-sg-panel]\");if(!b||!p)return;b.addEventListener(\"click\",function(){var o=p.hidden;p.hidden=!o;b.setAttribute(\"aria-expanded\",o?\"true\":\"false\");});});})();</script>{%- endunless -%}"
          }
